{
  "name": "fs-bridge-demo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && mkdir -p dist/public && cp -R src/public/* dist/public/",
    "watch": "tsc --watch",
    "serve": "nodemon dist/server.js",
    "dev": "npm-run-all --parallel watch serve",
    "clean": "rm -rf dist",
    "cleanbuild": "npm run clean && npm run build"
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
